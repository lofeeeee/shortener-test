APP_NAME="Link Shortener"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=shortener
DB_USERNAME=postgres
DB_PASSWORD=

HASH_DRIVER=argon2id

HASHIDS_SECRET=change-this-to-a-long-random-secret-key
HASHIDS_LENGTH=8

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
